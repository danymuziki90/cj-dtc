# ================================================================
# CJ Development Training Center — Variables Production
# Copiez ce fichier vers .env.production et renseignez les valeurs.
# Ne jamais committer ce fichier avec de vraies valeurs secrètes.
# ================================================================

# --- Base de données (Prisma / Supabase PostgreSQL) ---
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"

# --- Authentification NextAuth ---
NEXTAUTH_URL="https://cjdevelopmenttc.org"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
JWT_SECRET="replace-with-a-long-random-secret"
NEXT_PUBLIC_APP_URL="https://cjdevelopmenttc.org"
NEXT_RES_URL="https://cjdevelopmenttc.org"

# Connexion Google OAuth2 (optionnel)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# JWT dédiés portail admin / étudiant
ADMIN_JWT_SECRET="replace-with-a-long-random-admin-secret"
STUDENT_JWT_SECRET="replace-with-a-long-random-student-secret"
ADMIN_ALLOW_EMERGENCY_LOGIN="false"
ADMIN_DEFAULT_USERNAME="admincjtc"
ADMIN_DEFAULT_PASSWORD="disable-in-production"

# --- Email SMTP ---
MAIL_HOST="mail.cjdevelopmenttc.org"
MAIL_PORT="587"
MAIL_SECURE="false"
MAIL_USER="contact@cjdevelopmenttc.org"
MAIL_PASSWORD="replace-with-real-smtp-password"
MAIL_FROM="CJ DTC <contact@cjdevelopmenttc.org>"
MAIL_TLS_SERVERNAME="web-hosting.com"
EMAIL_DELIVERY_TIMEOUT_MS="8000"
CONTACT_EMAIL="contact@cjdevelopmenttc.org"

# --- Paiements Pawapay ---
PAWAPAY_API_KEY="replace-with-real-pawapay-key"
PAWAPAY_API_URL="https://api.sandbox.pawapay.io"
PAWAPAY_DEPOSIT_PATH="/v1/deposits"
PAWAPAY_DEPOSIT_STATUS_PATH="/v1/deposits/{depositId}"
PAWAPAY_PUBLIC_KEYS_PATH="/public-key/http"
PAWAPAY_COUNTRY_CODE="COD"
PAWAPAY_CALLBACK_URL="https://cjdevelopmenttc.org/pawapay/callback"
PAWAPAY_REQUIRE_SIGNED_CALLBACKS="false"

# --- Supabase (base de données & authentification) ---
# Obtenez ces valeurs dans Settings > API de votre projet Supabase
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_XXXX"

# --- Cloudflare R2 (stockage fichiers — solution unique) ---
# Activez ces variables pour utiliser Cloudflare R2.
# Sans elles, le projet utilise un fallback filesystem local (non recommandé en prod).
#
# Structure de dossiers dans le bucket :
#   formations/   — images et documents des formations
#   sessions/     — fichiers liés aux sessions
#   travaux/      — devoirs et projets des étudiants
#   certificats/  — certificats PDF (accès sécurisé via API)
#   actualites/   — images et médias des actualités
#   galerie/      — photos et vidéos de la galerie
#   partenaires/  — logos et documents des partenaires
#   etudiants/    — photos de profil et documents étudiants
#   logos/        — logos et branding de l'établissement
#
CLOUDFLARE_R2_ACCOUNT_ID="your-cloudflare-account-id"
CLOUDFLARE_R2_ACCESS_KEY_ID="your-r2-access-key-id"
CLOUDFLARE_R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
CLOUDFLARE_R2_BUCKET_NAME="cjdtc-bucket"
# URL publique du bucket (domaine personnalisé ou sous-domaine r2.dev activé dans Cloudflare)
CLOUDFLARE_R2_PUBLIC_URL="https://pub-1e5e8ef317024ae7900f84ad344983d0.r2.dev"
